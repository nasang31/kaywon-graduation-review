# Google Sheets Configuration
# If GOOGLE_SHEET_ID is provided, the app will use Google Sheets as the database
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Database Configuration
# If DB_HOST is provided, the app will use PostgreSQL (Cloud SQL)
# Otherwise, it will fallback to local SQLite (database.sqlite)
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432

# Authentication
JWT_SECRET=your-secret-key-change-this-in-production
