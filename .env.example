# ──────────────────────────────────────────
# Database Configuration (PostgreSQL)
# ──────────────────────────────────────────
# 방법 1 — 연결 문자열 (Railway, Supabase 등)
DATABASE_URL=

# 방법 2 — 개별 설정
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432

# ──────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────
# 반드시 변경하세요! (랜덤 문자열 권장)
JWT_SECRET=your-secret-key-change-this-in-production

# ──────────────────────────────────────────
# Supabase Storage (이미지 업로드)
# ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=work-images

# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
